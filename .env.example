# ─── Database ───────────────────────────────────────────────────────────────
# Hardcoded — dotenv does NOT expand ${VAR} references
DATABASE_URL="mysql://USERNAME:PASSWORD@localhost:3306/appliedagentic"

# ─── Authentication ──────────────────────────────────────────────────────────
AUTH_SECRET="generate-with: openssl rand -base64 32"
AUTH_URL="https://yourdomain.com"

# ─── OpenAI ──────────────────────────────────────────────────────────────────
# Required. Get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-your-openai-api-key-here"

# ─── Google Gemini ────────────────────────────────────────────────────────────
# Required only if you set provider='gemini' in any agents/*/config.ts file.
# Get yours at https://aistudio.google.com/app/apikey
GOOGLE_GENAI_API_KEY="your-google-ai-api-key-here"

# ─── LangChain Agents ────────────────────────────────────────────────────────
# All model names, temperature, max-tokens, and other per-agent settings are
# configured inside agents/<name>/config.ts — NOT here.
# To change the model or provider for an agent, edit its config.ts file.

# ─── Public Site ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="https://yourdomain.com"
NEXT_PUBLIC_SITE_NAME="Applied Agentic AI"

# ─── Debug / Logging ─────────────────────────────────────────────────────────
# true  → verbose logs written to ./logs/app.log and ./logs/error.log
# false → only warn+error, still written to log files
ENABLE_DEBUG_LOGS=false

# true → shows Quick Login button on login page. NEVER set in production.
NEXT_PUBLIC_QUICK_LOGIN=false
