# ─── Database ───────────────────────────────────────────────────────────────
DB_USER="USERNAME"
DB_PASSWORD="PASSWORD"
DB_HOST="localhost"
DB_PORT="3306"
DB_NAME="appliedagentic"
# NOTE: DATABASE_URL must be hardcoded — dotenv does NOT expand ${VAR} references
DATABASE_URL="mysql://USERNAME:PASSWORD@localhost:3306/appliedagentic"

# ─── Authentication ─────────────────────────────────────────────────────────
# NextAuth v5 uses AUTH_SECRET and AUTH_URL (replaces NEXTAUTH_SECRET / NEXTAUTH_URL)
AUTH_SECRET="generate-with: openssl rand -base64 32"
AUTH_URL="https://yourdomain.com"

# ─── OpenAI ─── All configurable from Admin → Settings → AI Config ──────────
OPENAI_API_KEY="sk-your-api-key-here"
OPENAI_TEXT_MODEL="gpt-4o"
OPENAI_IMAGE_MODEL="dall-e-3"
OPENAI_AUDIO_MODEL="tts-1"
OPENAI_TEMPERATURE="0.7"
OPENAI_MAX_TOKENS="2000"
OPENAI_IMAGE_SIZE="1024x1024"
OPENAI_IMAGE_QUALITY="standard"
OPENAI_TTS_VOICE="nova"

# ─── File Upload ────────────────────────────────────────────────────────────
UPLOAD_DIR="./public/uploads"
MAX_UPLOAD_SIZE_MB="10"

# ─── Public Site ────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="https://appliedagentic.com"
NEXT_PUBLIC_SITE_NAME="Applied Agentic AI"

# ─── Debug / Logging ────────────────────────────────────────────────────────
# Set to true on UAT/staging to enable verbose Prisma query logging and debug logs.
# Keep false (or omit) in production.
ENABLE_DEBUG_LOGS=false
# Set to true locally to show the Quick Login button on the login page. NEVER in production.
NEXT_PUBLIC_QUICK_LOGIN=false
