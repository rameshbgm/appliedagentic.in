# ─── Database ───────────────────────────────────────────────────────────────
# Hardcoded — dotenv does NOT expand ${VAR} references
DATABASE_URL="mysql://USERNAME:PASSWORD@localhost:3306/appliedagentic"

# ─── Authentication ──────────────────────────────────────────────────────────
AUTH_SECRET="generate-with: openssl rand -base64 32"
AUTH_URL="https://yourdomain.com"

# ─── OpenAI ──────────────────────────────────────────────────────────────────
# Only the API key is required. Model defaults are configured via Admin → Settings.
OPENAI_API_KEY="sk-your-api-key-here"

# ─── Public Site ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="https://yourdomain.com"
NEXT_PUBLIC_SITE_NAME="Applied Agentic AI"

# ─── Debug / Logging ─────────────────────────────────────────────────────────
# true  → verbose logs written to ./logs/app.log and ./logs/error.log
# false → only warn+error, still written to log files
ENABLE_DEBUG_LOGS=false

# true → shows Quick Login button on login page. NEVER set in production.
NEXT_PUBLIC_QUICK_LOGIN=false
